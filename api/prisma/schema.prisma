generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Tabela 1: Usuários
model User {
  id          String       @id @default(uuid())
  name        String
  email       String       @unique
  password    String
  role        Role         @default(EMPLOYEE)
  
  phone       String?      // Telefone/WhatsApp
  birthDate   DateTime?    // Data de Nascimento
  department  String?      // Departamento (Para RH)
  goal        String?      // Objetivo (Para Personal/Nutri)
  companyName String?      // Nome da Empresa / Consultório
  profession  String?      // Área de Atuação (RH, Personal, etc)
  
  gender        String?    // Sexo Biológico (M/F)
  height        Float?     // Altura em cm
  initialWeight Float?     // Peso inicial na primeira consulta
  allergies     String?    // Alergias / Intolerâncias
  pathologies   String?    // Patologias (Diabetes, HAS, etc)

  // ESTILO DE VIDA
  typicalSleep         String?    // Horas de sono por noite
  stressLevel          Int?       // Nível de estresse (1-5)
  foodRelationship     String?    // Relação com a comida / Compulsão
  psychologyHistory    String?    // Acompanhamento psicológico

  // ATIVIDADE FÍSICA
  exerciseType         String?    // Pratica exercício? Qual?
  exerciseFrequency    String?    // Frequência semanal
  exerciseDuration     String?    // Duração média
  hasPersonal          String?    // Tem personal/assessoria?
  workActivityLevel    String?    // Nível de atividade no trabalho

  // OBSERVAÇÕES DO PROFISSIONAL (Privado)
  nutritionistNotes    String?    @db.Text

  managerId   String?      // O ID do gestor que criou esta conta
  manager     User?        @relation("UserToManager", fields: [managerId], references: [id])
  employees   User[]       @relation("UserToManager")

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  
  workoutLogs WorkoutLog[]
  diets       DietPlan[]   @relation("UserDiets") // Relação com as dietas

  assessments PhysicalAssessment[] @relation("UserAssessments")
}

// Tabela 2: O Core da Resiliência Física e Mental
model WorkoutLog {
  id              String   @id @default(uuid())
  
  activityType    String   // Ex: Musculação, Corrida, Yoga, Meditação
  durationMinutes Int      // Duração em minutos
  intensity       String   // Ex: LEVE, MODERADO, INTENSO
  
  sleepHours      Float?   // Horas de sono na noite anterior
  moodLevel       Int?     // Nível de humor de 1 a 5

  notes           String?  // Campo de texto para as observações do aluno
  weight          Float?   // Peso em kg
  
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt       DateTime @default(now())

  @@map("workout_logs")
}

enum Role {
  ADMIN
  HR_MANAGER
  EMPLOYEE
}


// Tabela 3: O Planeamento Nutricional
model DietPlan {
  id          String   @id @default(uuid())
  title       String   // Ex: "Fase 1 - Emagrecimento Agressivo"
  goal        String   // Emagrecimento, Manutenção, Hipertrofia

  durationDays Int     @default(30)
  
  tmb         Float?   // Taxa Metabólica Basal calculada
  get         Float?   // Gasto Energético Total
  targetKcal  Float    // A meta final de calorias após o déficit/superávit
  
  proteinG    Float    
  fatG        Float    
  carbsG      Float    
  
  notes       String?  @db.Text 

  userId      String   
  user        User     @relation("UserDiets", fields: [userId], references: [id], onDelete: Cascade)
  creatorId   String   // ID do Nutricionista que montou

  isActive    Boolean  @default(true) // Para sabermos qual é a dieta atual do aluno
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  meals       Meal[]   @relation("DietMeals")

  @@map("diet_plans")
}

// 4. Tabela de Alimentos
model Food {
  id          String   @id @default(uuid())
  name        String
  baseUnit    String   @default("100g")
  baseAmount  Float    @default(100)
  
  // 📊 Macronutrientes Principais
  kcal        Float
  protein     Float
  carbs       Float
  fat         Float

  source      String   @default("MANUAL") 
  fiber       Float    @default(0)        
  sodium      Float    @default(0)        
  calcium     Float    @default(0)        
  iron        Float    @default(0)        

  // 🔗 Relação
  mealItems   MealItem[] 
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("foods") 
}


// 5. Refeições do Plano (Ex: Café da Manhã)
model Meal {
  id          String     @id @default(uuid())
  name        String     // Ex: "Café da Manhã", "Pré-Treino"
  time        String?    // Ex: "08:30"
  notes       String?    // Ex: "Consumir 30 min antes do treino"
  
  // Ligação com a Dieta do Aluno
  dietPlanId  String
  dietPlan    DietPlan   @relation("DietMeals", fields: [dietPlanId], references: [id], onDelete: Cascade)
  
  // Os alimentos que estão dentro desta refeição
  items       MealItem[] @relation("MealToItems")
  isConsumed Boolean    @default(false)
  
  @@map("meals")
}

// 6. O Alimento exato na quantidade exata para o Aluno
model MealItem {
  id          String     @id @default(uuid())
  quantity    Float      // Ex: 150 (Quantidade receitada)
  measure     String     // Ex: "g", "colheres de sopa", "unidade"
  notes       String?    // Ex: "Substitutos: Batata doce ou Mandioca"
  
  // Em qual refeição isto está?
  mealId      String
  meal        Meal       @relation("MealToItems", fields: [mealId], references: [id], onDelete: Cascade)
  
  // Qual é o alimento da tabela TACO?
  foodId      String
  food        Food       @relation(fields: [foodId], references: [id])
  
  @@map("meal_items")
}

// Tabela 7: Avaliações Físicas / Antropometria
model PhysicalAssessment {
  id          String   @id @default(uuid())
  date        DateTime @default(now()) // Data da consulta/avaliação
  
  // ⚖️ Medidas Globais
  weight      Float?   // Peso (kg)
  bodyFat     Float?   // Percentual de Gordura (%)
  muscleMass  Float?   // Massa Muscular (kg ou %)
  
  // 📏 Circunferências Principais (cm)
  waist       Float?   // Cintura
  abdomen     Float?   // Abdômen
  hips        Float?   // Quadril
  
  notes       String?  @db.Text

  // 🔗 Relação com o Paciente
  userId      String
  user        User     @relation("UserAssessments", fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("physical_assessments")
}

// Tabela 8: Memória de Medidas Caseiras (Dicionário do Nutri)
model FoodPreference {
  id              String   @id @default(uuid())
  
  nutritionistId  String   
  foodId          String   
  quantity        Float    @default(0) 
  measure         String   
  
  updatedAt       DateTime @updatedAt

  @@unique([nutritionistId, foodId, quantity])
  @@map("food_preferences")
}