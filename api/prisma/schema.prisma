// api/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Tabela 1: Usuários
model User {
  id          String       @id @default(uuid())
  name        String
  email       String       @unique
  password    String
  role        Role         @default(EMPLOYEE)
  
  phone       String?      // Telefone/WhatsApp
  birthDate   DateTime?    // Data de Nascimento
  department  String?      // Departamento (Para RH)
  goal        String?      // Objetivo (Para Personal/Nutri)
  companyName String?      // Nome da Empresa / Consultório
  profession  String?      // Área de Atuação (RH, Personal, etc)
  gender        String?    // Sexo Biológico (M/F)
  height        Float?     // Altura em cm
  initialWeight Float?     // Peso inicial na primeira consulta
  allergies     String?    // Alergias / Intolerâncias
  pathologies   String?    // Patologias (Diabetes, HAS, etc)

  // ESTILO DE VIDA
  typicalSleep         String?    // Horas de sono por noite
  stressLevel          Int?       // Nível de estresse (1-5)
  foodRelationship     String?    // Relação com a comida / Compulsão
  psychologyHistory    String?    // Acompanhamento psicológico

  // ATIVIDADE FÍSICA
  exerciseType         String?    // Pratica exercício? Qual?
  exerciseFrequency    String?    // Frequência semanal
  exerciseDuration     String?    // Duração média
  hasPersonal          String?    // Tem personal/assessoria?
  workActivityLevel    String?    // Nível de atividade no trabalho

  // OBSERVAÇÕES DO PROFISSIONAL (Privado)
  nutritionistNotes    String?    @db.Text

  managerId   String?      // O ID do gestor que criou esta conta
  manager     User?        @relation("UserToManager", fields: [managerId], references: [id])
  employees   User[]       @relation("UserToManager")

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  workoutLogs WorkoutLog[]
}

// Tabela 2: O Core da Resiliência Física e Mental
model WorkoutLog {
  id              String   @id @default(uuid())
  
  // Saúde Física
  activityType    String   // Ex: Musculação, Corrida, Yoga, Meditação
  durationMinutes Int      // Duração em minutos
  intensity       String   // Ex: LEVE, MODERADO, INTENSO
  
  // Saúde Mental e Recuperação
  sleepHours      Float?   // Horas de sono na noite anterior
  moodLevel       Int?     // Nível de humor de 1 a 5

  notes           String?  // Campo de texto para as observações do aluno
  weight          Float?   // Peso em kg
  
  // A Chave Estrangeira (De quem é esse treino?)
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt       DateTime @default(now())

  @@map("workout_logs")
}

enum Role {
  ADMIN
  HR_MANAGER
  EMPLOYEE
}