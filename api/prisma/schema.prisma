generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Tabela 1: Usuários (Pacientes e Profissionais)
model User {
  id          String       @id @default(uuid())
  name        String
  email       String       @unique
  password    String
  role        Role         @default(PATIENT)
  
  phone       String?
  birthDate   DateTime?    
  goal        String?
  companyName String?      
  profession  String?      // Fisio, Nutri, Personal (ou especialidade)
  
  gender        String?
  height        Float?
  initialWeight Float?     
  allergies     String?
  pathologies   String?    

  // ESTILO DE VIDA
  typicalSleep         String?
  stressLevel          Int?
  foodRelationship     String?
  psychologyHistory    String?

  // ATIVIDADE FÍSICA
  exerciseType         String?
  exerciseFrequency    String?    
  exerciseDuration     String?
  hasPersonal          String?    
  workActivityLevel    String?    

  // OBSERVAÇÕES DO PROFISSIONAL (Privado)
  nutritionistNotes    String? @db.Text

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  
  // workoutLogs   WorkoutLog[]
  
  diets         DietPlan[]   @relation("UserDiets") 
  
  createdDiets  DietPlan[]   @relation("CreatedDiets")

  assessments   PhysicalAssessment[] @relation("UserAssessments")

  patients      ProfessionalPatientLink[] @relation("ProfessionalLink")
  professionals ProfessionalPatientLink[] @relation("PatientLink")
}

model ProfessionalPatientLink {
  id             String   @id @default(uuid())
  
  professionalId String
  professional   User     @relation("ProfessionalLink", fields: [professionalId], references: [id], onDelete: Cascade)
  
  patientId      String
  patient        User     @relation("PatientLink", fields: [patientId], references: [id], onDelete: Cascade)
  
  isActive       Boolean  @default(true) // Permite inativar um paciente sem apagar os dados
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([professionalId, patientId]) // O mesmo nutri não se liga 2x ao mesmo paciente
  @@map("professional_patient_links")
}

enum Role {
  ADMIN
  PATIENT
  NUTRITIONIST
  PERSONAL
  PHYSIO
}

// Tabela 3: O Planeamento Nutricional
model DietPlan {
  id          String   @id @default(uuid())
  title       String   
  goal        String   

  durationDays Int     @default(30)
  
  tmb         Float?
  get         Float?
  targetKcal  Float    
  
  proteinG    Float    
  fatG        Float    
  carbsG      Float    
  
  notes       String? @db.Text 

  userId      String   
  user        User     @relation("UserDiets", fields: [userId], references: [id], onDelete: Cascade)
  
  creatorId   String   
  creator     User     @relation("CreatedDiets", fields: [creatorId], references: [id])

  isActive    Boolean  @default(true) 
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  meals       Meal[]   @relation("DietMeals")

  @@map("diet_plans")
}

// 4. Tabela de Alimentos
model Food {
  id          String   @id @default(uuid())
  name        String
  baseUnit    String   @default("100g")
  baseAmount  Float    @default(100)
  
  // 📊 Macronutrientes Principais
  kcal        Float
  protein     Float
  carbs       Float
  fat         Float

  source      String   @default("MANUAL") 
  fiber       Float    @default(0)        
  sodium      Float    @default(0)        
  calcium     Float    @default(0)        
  iron        Float    @default(0)        

  // 🔗 Relação
  mealItems   MealItem[] 
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("foods") 
}


// 5. Refeições do Plano (Ex: Café da Manhã)
model Meal {
  id          String     @id @default(uuid())
  name        String     // Ex: "Café da Manhã", "Pré-Treino"
  time        String?    // Ex: "08:30"
  notes       String?    // Ex: "Consumir 30 min antes do treino"
  
  // Ligação com a Dieta do Aluno
  dietPlanId  String
  dietPlan    DietPlan   @relation("DietMeals", fields: [dietPlanId], references: [id], onDelete: Cascade)
  
  // Os alimentos que estão dentro desta refeição
  items       MealItem[] @relation("MealToItems")
  isConsumed Boolean    @default(false)
  
  @@map("meals")
}

// 6. O Alimento exato na quantidade exata para o Aluno
model MealItem {
  id          String     @id @default(uuid())
  quantity    Float      // Ex: 150 (Quantidade receitada)
  measure     String     // Ex: "g", "colheres de sopa", "unidade"
  notes       String?    // Ex: "Substitutos: Batata doce ou Mandioca"
  
  // Em qual refeição isto está?
  mealId      String
  meal        Meal       @relation("MealToItems", fields: [mealId], references: [id], onDelete: Cascade)
  
  // Qual é o alimento da tabela TACO?
  foodId      String
  food        Food       @relation(fields: [foodId], references: [id])
  
  @@map("meal_items")
}

// Tabela 7: Avaliações Físicas / Antropometria
model PhysicalAssessment {
  id          String   @id @default(uuid())
  date        DateTime @default(now()) // Data da consulta/avaliação
  
  // ⚖️ Medidas Globais
  weight      Float?   // Peso (kg)
  bodyFat     Float?   // Percentual de Gordura (%)
  muscleMass  Float?   // Massa Muscular (kg ou %)
  
  // 📏 Circunferências Principais (cm)
  waist       Float?   // Cintura
  abdomen     Float?   // Abdômen
  hips        Float?   // Quadril
  
  notes       String?  @db.Text

  // 🔗 Relação com o Paciente
  userId      String
  user        User     @relation("UserAssessments", fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("physical_assessments")
}

// Tabela 8: Memória de Medidas Caseiras (Dicionário do Nutri)
model FoodPreference {
  id              String   @id @default(uuid())
  
  nutritionistId  String   
  foodId          String   
  quantity        Float    @default(0) 
  measure         String   
  
  updatedAt       DateTime @updatedAt

  @@unique([nutritionistId, foodId, quantity])
  @@map("food_preferences")
}